{
  "mcp": {
    "youtube-mcp": {
      "type": "local",
      "command": [
        "uv",
        "--directory",
        "/absolute/path/to/youtube-mcp",
        "run",
        "youtube-mcp",
        "serve",
        "--transport",
        "stdio"
      ],
      "environment": {
        "YOUTUBE_MCP_ENFORCE_GUARD": "1",
        "YOUTUBE_MCP_MUTATING_ALLOWED_HANDLE": "@your-channel-handle"
      }
    }
  }
}
